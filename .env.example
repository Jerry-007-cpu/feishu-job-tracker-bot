# =============================================================================
# .env.example —— 仅占位符，禁止填入真实值
# 真实值请复制到 .env（已 .gitignore），切勿提交
# =============================================================================

# 飞书应用凭证（飞书开放平台 → 你的应用 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret

# 飞书事件订阅（事件订阅页面）
# - VERIFICATION_TOKEN 用于事件签名校验
# - ENCRYPT_KEY 用于事件加密；如未在飞书后台启用加密，可留空
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=

# 多维表格信息（不要写真实值！）
BASE_TOKEN=your_bitable_app_token
MAIN_TABLE_ID=tblxxxxxxxxxxxxx
PROGRESS_TABLE_ID=tblxxxxxxxxxxxxx

# 第二阶段：自然语言兜底解析（第一阶段不用，保持注释）
# OPENAI_API_KEY=

# 服务端口
PORT=3000
