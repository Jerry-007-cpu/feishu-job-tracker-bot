# =============================================================================
# .env.example —— 仅占位符，禁止填入真实值
# 真实值请复制到 .env（已 .gitignore），切勿提交
# =============================================================================

# 飞书应用凭证（飞书开放平台 → 你的应用 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret

# 长连接模式不需要 Verification Token / Encrypt Key，保留为空即可
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# 多维表格信息（不要写真实值！）
# BASE_TOKEN 可以填真实 base token，也可以直接填完整 wiki/base 链接
BASE_TOKEN=https://example.feishu.cn/wiki/wiki_node_token?table=table_hint
# 可选：留空会自动选择名称包含"主表"或"投递记录"的表
MAIN_TABLE_ID=
PROGRESS_TABLE_ID=

# 服务端口
PORT=3000
